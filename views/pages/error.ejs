<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aeternorithm Project</title>
    <link rel="stylesheet" href="/css/pages/error.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <main class="error-page">
        <div class="error-code"><%= statusCode || 500 %></div>
        <h1 class="error-title"><%= title || 'Something went wrong' %></h1>
        <p class="error-message"><%= message || 'An unexpected error occurred. Please try again later.' %></p>
        <div class="error-buttons">
            <button class="btn btn-outline" onclick="history.back()">Go Back</button>
            <a href="/" class="btn btn-primary">Home</a>
        </div>
    </main>
    <script src="/js/security.js"></script>
</body>
</html>
