<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aeternorithm Project</title>
    <link rel="stylesheet" href="/css/pages/index.css">
    <link rel="stylesheet" href="/css/components/navbar.css">
    <link rel="stylesheet" href="/css/components/scrollbar.css">
    <link rel="stylesheet" href="/css/components/footer.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <%- include('../partials/navbar', { user: typeof user !== 'undefined' ? user : null, active: 'home' }) %>

    <!-- Hero Section -->
    <section class="hero">
        <div class="container hero-content">
            <p class="hero-greeting">Welcome to</p>
            <h1 class="hero-name">AETERNORITHM</h1>
            <p class="hero-role">Game Studio</p>
            <p class="hero-desc">We craft immersive gaming experiences with passion and precision.</p>
            <div class="hero-buttons">
                <a href="/about" class="btn btn-primary">Learn More</a>
                <% if (!user) { %>
                    <a href="/login" class="btn btn-outline">Sign In</a>
                <% } else { %>
                    <a href="/account" class="btn btn-outline">My Account</a>
                <% } %>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section class="section" id="about">
        <div class="container">
            <h2 class="section-title">About Us</h2>
            <div class="about-content">
                <p>Aeternorithm Project is an independent game studio dedicated to crafting immersive experiences. We believe in pushing creative boundaries and building worlds that players can lose themselves in.</p>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <ul class="footer-links">
                <li><a href="/terms">Terms</a></li>
                <li><a href="/privacy">Privacy</a></li>
            </ul>
            <p>&copy; 2026 Aeternorithm Project. All rights reserved.</p>
        </div>
    </footer>

    <script src="/js/navbar.js"></script>
    <script src="/js/security.js"></script>
</body>
</html>
