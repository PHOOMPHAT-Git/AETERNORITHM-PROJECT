<!DOCTYPE html>
<html lang="en" data-theme="<%= typeof theme !== 'undefined' ? theme : 'default' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aeternorithm Project</title>
    <link rel="stylesheet" href="/css/pages/ticket.css">
    <link rel="stylesheet" href="/css/components/navbar.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <%- include('../partials/theme-css') %>
</head>
<body>
    <%- include('../partials/navbar', { user: typeof user !== 'undefined' ? user : null, active: '' }) %>

    <main class="page">
        <div class="container">
            <a href="/" class="back-link">&larr; Back to Home</a>

            <div class="ticket-card">
                <div class="ticket-header">
                    <span class="ticket-label">AETERNORITHM</span>
                    <span class="ticket-label">GAME STUDIO</span>
                </div>
                <div class="ticket-body">
                    <h1 class="ticket-title">Aeternorithm</h1>
                    <p class="ticket-subtitle">Game Studio</p>
                </div>
                <div class="ticket-footer">
                    <div class="ticket-info">
                        <span class="ticket-info-label">Description</span>
                        <span class="ticket-info-value">An immersive online experience where nothing is quite what it seems.</span>
                    </div>
                    <div class="ticket-sep"></div>
                    <div class="ticket-info">
                        <span class="ticket-info-label">Reward</span>
                        <span class="ticket-info-value">1,000 THB</span>
                    </div>
                </div>
                <p class="ticket-congrats">Congratulations</p>
            </div>
        </div>
    </main>
    <script src="/js/navbar.js"></script>
    <script src="/js/security.js"></script>
</body>
</html>
