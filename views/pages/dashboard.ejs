<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aeternorithm Project</title>
    <link rel="stylesheet" href="/css/pages/dashboard.css">
    <link rel="stylesheet" href="/css/components/scrollbar.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <nav class="navbar">
        <div class="container nav-content">
            <a href="/" class="nav-logo">Aeternorithm</a>
            <div class="nav-menu">
                <ul class="nav-links">
                    <li><a href="/">Home</a></li>
                    <li><a href="/account"><%= user.username %></a></li>
                    <li><a href="/dashboard" class="active">Dashboard</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="page">
        <div class="container">
            <div class="page-header">
                <div>
                    <h1 class="page-title">Dashboard</h1>
                    <p class="page-subtitle">Player data overview</p>
                </div>
                <div class="header-actions">
                    <span class="status-dot" id="refreshStatus"></span>
                    <button class="btn btn-outline btn-sm" id="refreshBtn">Refresh</button>
                </div>
            </div>

            <!-- Stats Summary -->
            <div class="stats-row" id="statsRow">
                <div class="stat-card">
                    <span class="stat-value" id="totalMembers">-</span>
                    <span class="stat-label">Discord Members</span>
                </div>
                <div class="stat-card">
                    <span class="stat-value online" id="robloxVerified">-</span>
                    <span class="stat-label">Roblox Verified</span>
                </div>
                <div class="stat-card">
                    <span class="stat-value online" id="webLinked">-</span>
                    <span class="stat-label">Website Linked</span>
                </div>
            </div>

            <!-- Players Table -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">Members</h2>
                    <input type="text" class="search-input" id="searchInput" placeholder="Search by name or ID...">
                </div>
                <div class="table-wrap">
                    <table class="data-table" id="playersTable">
                        <thead>
                            <tr>
                                <th>Discord</th>
                                <th>Roblox Account</th>
                                <th>Roblox Verified</th>
                                <th>Website Linked</th>
                            </tr>
                        </thead>
                        <tbody id="playersBody">
                            <tr><td colspan="5" class="empty-state">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>
                <div class="pagination" id="pagination"></div>
            </div>

            <!-- Player Detail Modal -->
            <div class="modal-overlay" id="modalOverlay">
                <div class="modal">
                    <div class="modal-header">
                        <h3 class="modal-title" id="modalTitle">Player Details</h3>
                        <button class="modal-close" id="modalClose">&times;</button>
                    </div>
                    <div class="modal-body" id="modalBody"></div>
                    <div class="modal-footer">
                        <button class="btn btn-outline btn-sm" id="copyLayoutBtn">Copy Layout</button>
                        <button class="btn btn-primary btn-sm" id="editDataBtn">Edit Data</button>
                    </div>
                </div>
            </div>

            <!-- Edit Data Modal -->
            <div class="modal-overlay" id="editModalOverlay">
                <div class="modal modal-sm">
                    <div class="modal-header">
                        <h3 class="modal-title">Edit Player Data</h3>
                        <button class="modal-close" id="editModalClose">&times;</button>
                    </div>
                    <div class="modal-body">
                        <form id="editForm" class="edit-form">
                            <div class="form-group">
                                <label class="form-label">Discord Username</label>
                                <input type="text" class="form-input" id="editDiscordUsername" disabled>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Discord User ID</label>
                                <input type="text" class="form-input" id="editDiscordUserId" disabled>
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="editRobloxUsername">Roblox Username</label>
                                <input type="text" class="form-input" id="editRobloxUsername" placeholder="Auto-filled from Roblox ID on save">
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="editRobloxUserId">Roblox User ID</label>
                                <input type="text" class="form-input" id="editRobloxUserId" placeholder="Leave empty to unlink" inputmode="numeric">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Verification Status</label>
                                <div class="status-toggle" id="editStatus" role="radiogroup" aria-label="Verification Status">
                                    <button type="button" class="status-toggle-btn" data-value="verified" role="radio" aria-checked="false">Verified</button>
                                    <button type="button" class="status-toggle-btn" data-value="unverified" role="radio" aria-checked="false">Unverified</button>
                                </div>
                            </div>
                            <div class="form-error" id="editError"></div>
                            <div class="form-actions">
                                <button type="button" class="btn btn-outline btn-sm" id="editCancelBtn">Cancel</button>
                                <button type="submit" class="btn btn-primary btn-sm" id="editSaveBtn">Save Changes</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <footer class="footer">
        <div class="container">
            <p>&copy; 2026 Aeternorithm Project. All rights reserved.</p>
        </div>
    </footer>

    <script>
    (function() {
        var currentPlayers = [];
        var currentPage = 1;
        var totalPages = 1;
        var searchQuery = '';
        var searchTimer = null;
        var currentPlayerId = null;

        async function loadPlayers() {
            var btn = document.getElementById('refreshBtn');
            var dot = document.getElementById('refreshStatus');
            btn.disabled = true;
            btn.textContent = 'Loading...';
            dot.className = 'status-dot loading';

            try {
                var params = '?page=' + currentPage + '&limit=50';
                if (searchQuery) params += '&search=' + encodeURIComponent(searchQuery);
                var res = await fetch('/api/game/players' + params);
                var data = await res.json();
                if (data.success) {
                    currentPlayers = data.players;
                    totalPages = data.pagination.pages || 1;
                    renderStats(data.stats);
                    renderTable(currentPlayers);
                    renderPagination(data.pagination);
                    dot.className = 'status-dot success';
                } else {
                    dot.className = 'status-dot error';
                }
            } catch(e) {
                dot.className = 'status-dot error';
            }
            btn.disabled = false;
            btn.textContent = 'Refresh';
        }

        function renderStats(stats) {
            document.getElementById('totalMembers').textContent = stats.total || 0;
            document.getElementById('robloxVerified').textContent = (stats.roblox_verified || 0) + ' / ' + ((stats.total || 0) - (stats.roblox_verified || 0));
            document.getElementById('webLinked').textContent = (stats.website_linked || 0) + ' / ' + ((stats.total || 0) - (stats.website_linked || 0));
        }

        function formatDate(date) {
            if (!date) return '-';
            var d = new Date(date);
            return d.toLocaleDateString('th-TH', { day: '2-digit', month: '2-digit', year: 'numeric' }) + ' ' +
                   d.toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit' });
        }

        function renderTable(players) {
            var tbody = document.getElementById('playersBody');
            if (players.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" class="empty-state">No members found</td></tr>';
                return;
            }
            tbody.innerHTML = players.map(function(p) {
                // Discord column
                var discordHtml = '<div class="member-info">';
                if (p.discord_avatar) discordHtml += '<img class="member-avatar" src="' + esc(p.discord_avatar) + '" alt="">';
                discordHtml += '<span>' + esc(p.discord_display_name || p.discord_username) + '</span></div>';

                // Roblox account column
                var robloxHtml = p.roblox_verified
                    ? '<span class="verify-badge roblox">' + esc(p.roblox_username || String(p.roblox_user_id)) + '</span>'
                    : '<span class="verify-badge none">Not Verified</span>';

                // Roblox verified at
                var robloxDateHtml = p.roblox_verified_at
                    ? '<span class="muted">' + formatDate(p.roblox_verified_at) + '</span>'
                    : '<span class="muted">-</span>';

                // Web linked
                var webDateHtml = p.website_linked
                    ? '<span class="verify-badge full">' + esc(p.website_username) + '</span>'
                    : '<span class="verify-badge none">Not Linked</span>';

                return '<tr class="clickable-row" data-id="' + p._id + '">' +
                    '<td class="discord-cell">' + discordHtml + '</td>' +
                    '<td class="player-cell">' + robloxHtml + '</td>' +
                    '<td class="muted">' + robloxDateHtml + '</td>' +
                    '<td>' + webDateHtml + '</td>' +
                '</tr>';
            }).join('');
        }

        function renderPagination(pg) {
            var el = document.getElementById('pagination');
            if (pg.pages <= 1) { el.innerHTML = ''; return; }

            var html = '';
            html += '<button class="pg-btn" ' + (pg.page <= 1 ? 'disabled' : '') + ' data-page="' + (pg.page - 1) + '">&lsaquo;</button>';

            var start = Math.max(1, pg.page - 2);
            var end = Math.min(pg.pages, pg.page + 2);
            if (start > 1) html += '<button class="pg-btn" data-page="1">1</button><span class="pg-dots">...</span>';
            for (var i = start; i <= end; i++) {
                html += '<button class="pg-btn' + (i === pg.page ? ' active' : '') + '" data-page="' + i + '">' + i + '</button>';
            }
            if (end < pg.pages) html += '<span class="pg-dots">...</span><button class="pg-btn" data-page="' + pg.pages + '">' + pg.pages + '</button>';

            html += '<button class="pg-btn" ' + (pg.page >= pg.pages ? 'disabled' : '') + ' data-page="' + (pg.page + 1) + '">&rsaquo;</button>';
            el.innerHTML = html;
        }

        function esc(str) {
            var d = document.createElement('div');
            d.textContent = str;
            return d.innerHTML;
        }

        function showModal(playerId) {
            var p = currentPlayers.find(function(pl) { return pl._id === playerId; });
            if (!p) return;

            currentPlayerId = playerId;
            document.getElementById('modalTitle').textContent =
                p.discord_display_name || p.discord_username || p.roblox_username || 'Unknown';

            var html = '<div class="detail-grid">';

            // Discord Info
            html += '<div class="detail-section"><h4>Discord</h4><div class="detail-list">';
            html += detailRow('Discord ID', p.discord_user_id || '-');
            html += detailRow('Username', p.discord_username || '-');
            html += detailRow('Display Name', p.discord_display_name || '-');
            var dsStatus = p.discord_status === 'online' ? '<span class="status-badge online">Online</span>' :
                           p.discord_status === 'idle' ? '<span class="status-badge idle">Idle</span>' :
                           p.discord_status === 'dnd' ? '<span class="status-badge dnd">DND</span>' :
                           '<span class="status-badge offline">Offline</span>';
            html += detailRow('Status', dsStatus);
            if (p.discord_joined_at) html += detailRow('Joined Server', new Date(p.discord_joined_at).toLocaleString());
            html += '</div></div>';

            // Roblox Verification
            html += '<div class="detail-section"><h4>Roblox Verification</h4><div class="detail-list">';
            var rVerify = p.roblox_verified ? '<span class="verify-badge roblox">Verified</span>' : '<span class="verify-badge none">Not Verified</span>';
            html += detailRow('Status', rVerify);
            html += detailRow('Roblox Account', p.roblox_username || (p.roblox_user_id ? String(p.roblox_user_id) : '-'));
            html += detailRow('Roblox ID', p.roblox_user_id || '-');
            if (p.roblox_verified_at) html += detailRow('Verified At', new Date(p.roblox_verified_at).toLocaleString());
            html += '</div></div>';

            // Website Verification
            html += '<div class="detail-section"><h4>Website Verification</h4><div class="detail-list">';
            var wVerify = p.website_linked ? '<span class="verify-badge full">Linked</span>' : '<span class="verify-badge none">Not Linked</span>';
            html += detailRow('Status', wVerify);
            if (p.website_linked_at) html += detailRow('Linked At', new Date(p.website_linked_at).toLocaleString());
            html += '</div></div>';

            html += '</div>';

            document.getElementById('modalBody').innerHTML = html;
            document.getElementById('modalOverlay').classList.add('active');
        }

        function detailRow(label, value) {
            return '<div class="detail-row"><span class="detail-label">' + label + '</span><span class="detail-value">' + value + '</span></div>';
        }

        // Events
        document.getElementById('refreshBtn').addEventListener('click', function() {
            loadPlayers();
        });

        document.getElementById('searchInput').addEventListener('input', function() {
            var q = this.value.trim();
            clearTimeout(searchTimer);
            searchTimer = setTimeout(function() {
                searchQuery = q;
                currentPage = 1;
                loadPlayers();
            }, 300);
        });

        document.getElementById('pagination').addEventListener('click', function(e) {
            var btn = e.target.closest('.pg-btn');
            if (btn && !btn.disabled) {
                currentPage = parseInt(btn.dataset.page);
                loadPlayers();
            }
        });

        document.getElementById('playersBody').addEventListener('click', function(e) {
            var row = e.target.closest('.clickable-row');
            if (row) showModal(row.dataset.id);
        });

        document.getElementById('modalClose').addEventListener('click', function() {
            document.getElementById('modalOverlay').classList.remove('active');
        });
        document.getElementById('modalOverlay').addEventListener('click', function(e) {
            if (e.target === this) this.classList.remove('active');
        });

        // Copy Layout button
        document.getElementById('copyLayoutBtn').addEventListener('click', function() {
            var p = currentPlayers.find(function(pl) { return pl._id === currentPlayerId; });
            if (!p) return;

            var discordName = p.discord_username || p.discord_display_name || 'Unknown';
            var text = discordName + '\n' +
                'Discord UserID : ' + (p.discord_user_id || '-') + '\n' +
                'Roblox Username : ' + (p.roblox_username || '-') + '\n' +
                'Roblox UserID : ' + (p.roblox_user_id || '-');

            var btn = this;
            var original = btn.textContent;
            function done(ok) {
                btn.textContent = ok ? 'Copied!' : 'Copy failed';
                setTimeout(function() { btn.textContent = original; }, 1500);
            }

            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(text).then(function() { done(true); }, function() { done(false); });
            } else {
                // Fallback
                var ta = document.createElement('textarea');
                ta.value = text;
                ta.style.position = 'fixed';
                ta.style.opacity = '0';
                document.body.appendChild(ta);
                ta.select();
                try { document.execCommand('copy'); done(true); } catch(e) { done(false); }
                document.body.removeChild(ta);
            }
        });

        // Verification status toggle helpers
        function setStatusToggle(value) {
            var btns = document.querySelectorAll('#editStatus .status-toggle-btn');
            btns.forEach(function(b) {
                var active = b.getAttribute('data-value') === value;
                b.classList.toggle('active', active);
                b.setAttribute('aria-checked', active ? 'true' : 'false');
            });
        }
        function getStatusToggle() {
            var active = document.querySelector('#editStatus .status-toggle-btn.active');
            return active ? active.getAttribute('data-value') : 'unverified';
        }
        document.querySelectorAll('#editStatus .status-toggle-btn').forEach(function(b) {
            b.addEventListener('click', function() {
                setStatusToggle(b.getAttribute('data-value'));
            });
        });

        // Edit Data button — open edit modal
        document.getElementById('editDataBtn').addEventListener('click', function() {
            var p = currentPlayers.find(function(pl) { return pl._id === currentPlayerId; });
            if (!p) return;

            document.getElementById('editDiscordUsername').value = p.discord_display_name || p.discord_username || '';
            document.getElementById('editDiscordUserId').value = p.discord_user_id || '';
            document.getElementById('editRobloxUsername').value = p.roblox_username || '';
            document.getElementById('editRobloxUserId').value = p.roblox_user_id || '';
            setStatusToggle(p.roblox_verified ? 'verified' : 'unverified');
            document.getElementById('editError').textContent = '';

            document.getElementById('editModalOverlay').classList.add('active');
        });

        // Edit modal close handlers
        document.getElementById('editModalClose').addEventListener('click', function() {
            document.getElementById('editModalOverlay').classList.remove('active');
        });
        document.getElementById('editCancelBtn').addEventListener('click', function() {
            document.getElementById('editModalOverlay').classList.remove('active');
        });
        document.getElementById('editModalOverlay').addEventListener('click', function(e) {
            if (e.target === this) this.classList.remove('active');
        });

        // Submit edit form
        document.getElementById('editForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            var p = currentPlayers.find(function(pl) { return pl._id === currentPlayerId; });
            if (!p || !p.discord_user_id) return;

            var errorEl = document.getElementById('editError');
            var saveBtn = document.getElementById('editSaveBtn');
            errorEl.textContent = '';

            var robloxIdRaw = document.getElementById('editRobloxUserId').value.trim();
            var robloxUsername = document.getElementById('editRobloxUsername').value.trim();
            var status = getStatusToggle();

            var payload;
            if (robloxIdRaw === '') {
                payload = { roblox_user_id: null };
            } else {
                if (!/^\d+$/.test(robloxIdRaw)) {
                    errorEl.textContent = 'Roblox User ID must be a positive number.';
                    return;
                }
                payload = {
                    roblox_user_id: Number(robloxIdRaw),
                    roblox_username: robloxUsername,
                    status: status
                };
            }

            saveBtn.disabled = true;
            saveBtn.textContent = 'Saving...';

            try {
                var res = await fetch('/api/game/players/' + encodeURIComponent(p.discord_user_id), {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                var data = await res.json();
                if (!res.ok || !data.success) {
                    throw new Error(data.error || 'Request failed');
                }
                document.getElementById('editModalOverlay').classList.remove('active');
                document.getElementById('modalOverlay').classList.remove('active');
                loadPlayers();
            } catch (err) {
                errorEl.textContent = err.message || 'Failed to save changes.';
            } finally {
                saveBtn.disabled = false;
                saveBtn.textContent = 'Save Changes';
            }
        });

        // Auto refresh every 30s
        loadPlayers();
        setInterval(loadPlayers, 30000);
    })();
    </script>
    <script src="/js/security.js"></script>
</body>
</html>
