<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aeternorithm Project</title>
    <link rel="stylesheet" href="/css/pages/dashboard.css">
    <link rel="stylesheet" href="/css/components/scrollbar.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <nav class="navbar">
        <div class="container nav-content">
            <a href="/" class="nav-logo">Aeternorithm</a>
            <div class="nav-menu">
                <ul class="nav-links">
                    <li><a href="/">Home</a></li>
                    <li><a href="/account"><%= user.username %></a></li>
                    <li><a href="/dashboard" class="active">Dashboard</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="page">
        <div class="container">
            <div class="page-header">
                <div>
                    <h1 class="page-title">Dashboard</h1>
                    <p class="page-subtitle">Player data overview</p>
                </div>
                <div class="header-actions">
                    <span class="status-dot" id="refreshStatus"></span>
                    <button class="btn btn-outline btn-sm" id="refreshBtn">Refresh</button>
                </div>
            </div>

            <!-- Stats Summary -->
            <div class="stats-row" id="statsRow">
                <div class="stat-card">
                    <span class="stat-value" id="totalMembers">-</span>
                    <span class="stat-label">Discord Members</span>
                </div>
                <div class="stat-card">
                    <span class="stat-value online" id="discordOnline">-</span>
                    <span class="stat-label">Discord Online</span>
                </div>
                <div class="stat-card">
                    <span class="stat-value online" id="onlinePlayers">-</span>
                    <span class="stat-label">In-Game</span>
                </div>
                <div class="stat-card">
                    <span class="stat-value offline" id="offlinePlayers">-</span>
                    <span class="stat-label">Offline</span>
                </div>
            </div>

            <!-- Players Table -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">Members</h2>
                    <input type="text" class="search-input" id="searchInput" placeholder="Search by name or ID...">
                </div>
                <div class="table-wrap">
                    <table class="data-table" id="playersTable">
                        <thead>
                            <tr>
                                <th>Status</th>
                                <th>Discord</th>
                                <th>Roblox</th>
                                <th>Game</th>
                                <th>Verify</th>
                                <th>Last Seen</th>
                            </tr>
                        </thead>
                        <tbody id="playersBody">
                            <tr><td colspan="6" class="empty-state">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>
                <div class="pagination" id="pagination"></div>
            </div>

            <!-- Player Detail Modal -->
            <div class="modal-overlay" id="modalOverlay">
                <div class="modal">
                    <div class="modal-header">
                        <h3 class="modal-title" id="modalTitle">Player Details</h3>
                        <button class="modal-close" id="modalClose">&times;</button>
                    </div>
                    <div class="modal-body" id="modalBody"></div>
                </div>
            </div>
        </div>
    </main>

    <footer class="footer">
        <div class="container">
            <p>&copy; 2026 Aeternorithm Project. All rights reserved.</p>
        </div>
    </footer>

    <script>
    (function() {
        var currentPlayers = [];
        var currentPage = 1;
        var totalPages = 1;
        var searchQuery = '';
        var searchTimer = null;

        function timeAgo(date) {
            var now = Date.now();
            var diff = now - new Date(date).getTime();
            var mins = Math.floor(diff / 60000);
            if (mins < 1) return 'Just now';
            if (mins < 60) return mins + 'm ago';
            var hours = Math.floor(mins / 60);
            if (hours < 24) return hours + 'h ago';
            var days = Math.floor(hours / 24);
            return days + 'd ago';
        }

        async function loadPlayers() {
            var btn = document.getElementById('refreshBtn');
            var dot = document.getElementById('refreshStatus');
            btn.disabled = true;
            btn.textContent = 'Loading...';
            dot.className = 'status-dot loading';

            try {
                var params = '?page=' + currentPage + '&limit=50';
                if (searchQuery) params += '&search=' + encodeURIComponent(searchQuery);
                var res = await fetch('/api/game/players' + params);
                var data = await res.json();
                if (data.success) {
                    currentPlayers = data.players;
                    totalPages = data.pagination.pages || 1;
                    renderStats(data.stats);
                    renderTable(currentPlayers);
                    renderPagination(data.pagination);
                    dot.className = 'status-dot success';
                } else {
                    dot.className = 'status-dot error';
                }
            } catch(e) {
                dot.className = 'status-dot error';
            }
            btn.disabled = false;
            btn.textContent = 'Refresh';
        }

        function renderStats(stats) {
            document.getElementById('totalMembers').textContent = stats.discord_total || stats.total;
            document.getElementById('discordOnline').textContent = stats.discord_online || 0;
            document.getElementById('onlinePlayers').textContent = stats.online;
            document.getElementById('offlinePlayers').textContent = stats.offline;
        }

        function renderTable(players) {
            var tbody = document.getElementById('playersBody');
            if (players.length === 0) {
                tbody.innerHTML = '<tr><td colspan="6" class="empty-state">No members found</td></tr>';
                return;
            }
            tbody.innerHTML = players.map(function(p) {
                // Status column - show Discord status + in-game
                var statusHtml = '';
                if (p.is_online) {
                    statusHtml = '<span class="status-badge online">In-Game</span>';
                } else {
                    var dsClass = p.discord_status === 'online' ? 'online' : (p.discord_status === 'idle' ? 'idle' : (p.discord_status === 'dnd' ? 'dnd' : 'offline'));
                    var dsLabel = p.discord_status === 'online' ? 'Online' : (p.discord_status === 'idle' ? 'Idle' : (p.discord_status === 'dnd' ? 'DND' : 'Offline'));
                    statusHtml = '<span class="status-badge ' + dsClass + '">' + dsLabel + '</span>';
                }

                // Discord column
                var discordHtml = '';
                if (p.discord_username) {
                    discordHtml = '<div class="member-info">';
                    if (p.discord_avatar) discordHtml += '<img class="member-avatar" src="' + esc(p.discord_avatar) + '" alt="">';
                    discordHtml += '<span>' + esc(p.discord_display_name || p.discord_username) + '</span></div>';
                } else if (p.discord_user_id) {
                    discordHtml = '<span class="muted">' + esc(p.discord_user_id) + '</span>';
                } else {
                    discordHtml = '<span class="muted">-</span>';
                }

                // Roblox column
                var robloxHtml = p.roblox_username ? esc(p.roblox_username) : '<span class="muted">-</span>';

                // Game status
                var gameHtml = p.has_played ? (p.is_online ? '<span class="verify-badge full">Playing</span>' : '<span class="verify-badge roblox">Played</span>') : '<span class="verify-badge none">Never</span>';

                // Verify
                var verifyStatus = '';
                if (p.roblox_verified && p.website_linked) {
                    verifyStatus = '<span class="verify-badge full">Roblox + Web</span>';
                } else if (p.roblox_verified) {
                    verifyStatus = '<span class="verify-badge roblox">Roblox</span>';
                } else {
                    verifyStatus = '<span class="verify-badge none">None</span>';
                }

                // Last seen
                var lastSeenHtml = p.last_seen ? timeAgo(p.last_seen) : '<span class="muted">-</span>';

                return '<tr class="clickable-row" data-id="' + p._id + '">' +
                    '<td>' + statusHtml + '</td>' +
                    '<td class="discord-cell">' + discordHtml + '</td>' +
                    '<td class="player-cell">' + robloxHtml + '</td>' +
                    '<td>' + gameHtml + '</td>' +
                    '<td>' + verifyStatus + '</td>' +
                    '<td class="muted">' + lastSeenHtml + '</td>' +
                '</tr>';
            }).join('');
        }

        function renderPagination(pg) {
            var el = document.getElementById('pagination');
            if (pg.pages <= 1) { el.innerHTML = ''; return; }

            var html = '';
            html += '<button class="pg-btn" ' + (pg.page <= 1 ? 'disabled' : '') + ' data-page="' + (pg.page - 1) + '">&lsaquo;</button>';

            var start = Math.max(1, pg.page - 2);
            var end = Math.min(pg.pages, pg.page + 2);
            if (start > 1) html += '<button class="pg-btn" data-page="1">1</button><span class="pg-dots">...</span>';
            for (var i = start; i <= end; i++) {
                html += '<button class="pg-btn' + (i === pg.page ? ' active' : '') + '" data-page="' + i + '">' + i + '</button>';
            }
            if (end < pg.pages) html += '<span class="pg-dots">...</span><button class="pg-btn" data-page="' + pg.pages + '">' + pg.pages + '</button>';

            html += '<button class="pg-btn" ' + (pg.page >= pg.pages ? 'disabled' : '') + ' data-page="' + (pg.page + 1) + '">&rsaquo;</button>';
            el.innerHTML = html;
        }

        function esc(str) {
            var d = document.createElement('div');
            d.textContent = str;
            return d.innerHTML;
        }

        function showModal(playerId) {
            var p = currentPlayers.find(function(pl) { return pl._id === playerId; });
            if (!p) return;

            document.getElementById('modalTitle').textContent =
                p.discord_display_name || p.discord_username || p.roblox_username || 'Unknown';

            var html = '<div class="detail-grid">';

            // Discord Info
            html += '<div class="detail-section"><h4>Discord</h4><div class="detail-list">';
            html += detailRow('Discord ID', p.discord_user_id || '-');
            html += detailRow('Username', p.discord_username || '-');
            html += detailRow('Display Name', p.discord_display_name || '-');
            var dsStatus = p.discord_status === 'online' ? '<span class="status-badge online">Online</span>' :
                           p.discord_status === 'idle' ? '<span class="status-badge idle">Idle</span>' :
                           p.discord_status === 'dnd' ? '<span class="status-badge dnd">DND</span>' :
                           '<span class="status-badge offline">Offline</span>';
            html += detailRow('Status', dsStatus);
            if (p.discord_joined_at) html += detailRow('Joined Server', new Date(p.discord_joined_at).toLocaleString());
            html += '</div></div>';

            // Game Info
            html += '<div class="detail-section"><h4>Game</h4><div class="detail-list">';
            html += detailRow('Roblox ID', p.roblox_user_id || '-');
            html += detailRow('Roblox Username', p.roblox_username || '-');
            html += detailRow('In-Game', p.is_online ? '<span class="status-badge online">Online</span>' : '<span class="status-badge offline">Offline</span>');
            html += detailRow('Has Played', p.has_played ? 'Yes' : 'No');
            if (p.last_seen) html += detailRow('Last Seen', new Date(p.last_seen).toLocaleString());
            html += '</div></div>';

            // Verification
            html += '<div class="detail-section"><h4>Verification</h4><div class="detail-list">';
            var rVerify = p.roblox_verified ? '<span class="verify-badge roblox">Verified</span>' : '<span class="verify-badge none">Not Verified</span>';
            html += detailRow('Roblox Verify', rVerify);
            var wVerify = p.website_linked ? '<span class="verify-badge full">Linked (' + esc(p.website_username || '') + ')</span>' : '<span class="verify-badge none">Not Linked</span>';
            html += detailRow('Website Verify', wVerify);
            if (p.verified_at) html += detailRow('Verified At', new Date(p.verified_at).toLocaleString());
            html += '</div></div>';

            html += '</div>';

            document.getElementById('modalBody').innerHTML = html;
            document.getElementById('modalOverlay').classList.add('active');
        }

        function detailRow(label, value) {
            return '<div class="detail-row"><span class="detail-label">' + label + '</span><span class="detail-value">' + value + '</span></div>';
        }

        // Events
        document.getElementById('refreshBtn').addEventListener('click', function() {
            loadPlayers();
        });

        document.getElementById('searchInput').addEventListener('input', function() {
            var q = this.value.trim();
            clearTimeout(searchTimer);
            searchTimer = setTimeout(function() {
                searchQuery = q;
                currentPage = 1;
                loadPlayers();
            }, 300);
        });

        document.getElementById('pagination').addEventListener('click', function(e) {
            var btn = e.target.closest('.pg-btn');
            if (btn && !btn.disabled) {
                currentPage = parseInt(btn.dataset.page);
                loadPlayers();
            }
        });

        document.getElementById('playersBody').addEventListener('click', function(e) {
            var row = e.target.closest('.clickable-row');
            if (row) showModal(row.dataset.id);
        });

        document.getElementById('modalClose').addEventListener('click', function() {
            document.getElementById('modalOverlay').classList.remove('active');
        });
        document.getElementById('modalOverlay').addEventListener('click', function(e) {
            if (e.target === this) this.classList.remove('active');
        });

        // Auto refresh every 30s
        loadPlayers();
        setInterval(loadPlayers, 30000);
    })();
    </script>
    <script src="/js/security.js"></script>
</body>
</html>
