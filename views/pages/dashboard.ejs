<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aeternorithm Project</title>
    <link rel="stylesheet" href="/css/pages/dashboard.css">
    <link rel="stylesheet" href="/css/components/navbar.css">
    <link rel="stylesheet" href="/css/components/scrollbar.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <%- include('../partials/navbar', { user: typeof user !== 'undefined' ? user : null, active: 'dashboard' }) %>

    <main class="page">
        <div class="container">
            <div class="page-header">
                <div>
                    <h1 class="page-title">Dashboard</h1>
                    <p class="page-subtitle">Player data overview</p>
                </div>
                <div class="header-actions">
                    <span class="status-dot" id="refreshStatus"></span>
                    <button class="btn btn-outline btn-sm" id="refreshBtn">Refresh</button>
                </div>
            </div>

            <!-- Stats Summary -->
            <div class="stats-row" id="statsRow">
                <div class="stat-card">
                    <span class="stat-value" id="totalMembers">-</span>
                    <span class="stat-label">Discord Members</span>
                </div>
                <div class="stat-card">
                    <span class="stat-value online" id="robloxVerified">-</span>
                    <span class="stat-label">Roblox Verified</span>
                </div>
                <div class="stat-card">
                    <span class="stat-value online" id="webLinked">-</span>
                    <span class="stat-label">Website Linked</span>
                </div>
                <div class="stat-card">
                    <span class="stat-value" id="totalWarned">-</span>
                    <span class="stat-label">Warned</span>
                </div>
                <div class="stat-card">
                    <span class="stat-value" id="totalBanned">-</span>
                    <span class="stat-label">Banned</span>
                </div>
            </div>

            <!-- Players Table -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">Members</h2>
                    <input type="text" class="search-input" id="searchInput" placeholder="Search by name or ID...">
                </div>
                <div class="table-wrap">
                    <table class="data-table" id="playersTable">
                        <thead>
                            <tr>
                                <th>Discord</th>
                                <th>Roblox Account</th>
                                <th>Roblox Verified</th>
                                <th>Website Linked</th>
                                <th>Moderation</th>
                            </tr>
                        </thead>
                        <tbody id="playersBody">
                            <tr><td colspan="5" class="empty-state">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>
                <div class="pagination" id="pagination"></div>
            </div>

            <div class="card creators-card">
                <div class="card-header">
                    <h2 class="card-title">Creators / Connections</h2>
                    <div class="card-header-actions">
                        <input type="text" class="search-input" id="creatorSearchInput" placeholder="Search creators...">
                        <button class="btn btn-primary btn-sm" id="addCreatorBtn">Add Creator</button>
                    </div>
                </div>
                <div class="creator-admin-list" id="creatorAdminList">
                    <p class="empty-state">Loading...</p>
                </div>
            </div>

            <div class="modal-overlay" id="creatorModalOverlay">
                <div class="modal modal-sm">
                    <div class="modal-header">
                        <h3 class="modal-title" id="creatorModalTitle">Add Creator</h3>
                        <button class="modal-close" id="creatorModalClose">&times;</button>
                    </div>
                    <div class="modal-body">
                        <form id="creatorForm" class="edit-form">
                            <div class="form-group">
                                <label class="form-label" for="creatorName">Name</label>
                                <input type="text" class="form-input" id="creatorName" required maxlength="80">
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="creatorHandle">Handle</label>
                                <input type="text" class="form-input" id="creatorHandle" placeholder="@username" required maxlength="80">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Platform</label>
                                <div class="status-toggle" id="creatorPlatform" role="radiogroup" aria-label="Platform">
                                    <button type="button" class="status-toggle-btn platform-youtube" data-value="youtube" role="radio" aria-checked="false">YouTube</button>
                                    <button type="button" class="status-toggle-btn platform-tiktok" data-value="tiktok" role="radio" aria-checked="false">TikTok</button>
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="creatorUrl">Profile URL</label>
                                <div class="card-header-actions" style="gap:8px;">
                                    <input type="url" class="form-input" id="creatorUrl" placeholder="https://www.youtube.com/@channel" required style="flex:1;">
                                    <button type="button" class="btn btn-outline btn-sm" id="creatorFetchBtn">Fetch</button>
                                </div>
                                <p class="form-hint" id="creatorFetchHint" style="margin-top:6px;font-size:12px;opacity:0.75;">Paste a YouTube channel URL and click Fetch to auto-fill the rest.</p>
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="creatorAvatar">Avatar URL or Path</label>
                                <input type="text" class="form-input" id="creatorAvatar" placeholder="/images/foo.png or https://...">
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="creatorBanner">Banner URL or Path</label>
                                <input type="text" class="form-input" id="creatorBanner" placeholder="https://... (optional)">
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="creatorFollowers">Followers (display text)</label>
                                <input type="text" class="form-input" id="creatorFollowers" placeholder="12K">
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="creatorOrder">Order</label>
                                <input type="number" class="form-input" id="creatorOrder" value="0" step="1">
                            </div>
                            <div class="form-error" id="creatorError"></div>
                            <div class="form-actions">
                                <button type="button" class="btn btn-danger btn-sm" id="creatorDeleteBtn" hidden>Delete</button>
                                <button type="button" class="btn btn-outline btn-sm" id="creatorCancelBtn">Cancel</button>
                                <button type="submit" class="btn btn-primary btn-sm" id="creatorSaveBtn">Save</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="modal-overlay" id="modalOverlay">
                <div class="modal">
                    <div class="modal-header">
                        <h3 class="modal-title" id="modalTitle">Player Details</h3>
                        <button class="modal-close" id="modalClose">&times;</button>
                    </div>
                    <div class="modal-body" id="modalBody"></div>
                    <div class="modal-footer">
                        <button class="btn btn-outline btn-sm" id="copyLayoutBtn">Copy Layout</button>
                        <button class="btn btn-primary btn-sm" id="editDataBtn">Edit Data</button>
                    </div>
                </div>
            </div>

            <!-- Edit Data Modal -->
            <div class="modal-overlay" id="editModalOverlay">
                <div class="modal modal-sm">
                    <div class="modal-header">
                        <h3 class="modal-title">Edit Player Data</h3>
                        <button class="modal-close" id="editModalClose">&times;</button>
                    </div>
                    <div class="modal-body">
                        <form id="editForm" class="edit-form">
                            <div class="form-group">
                                <label class="form-label">Discord Username</label>
                                <input type="text" class="form-input" id="editDiscordUsername" disabled>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Discord User ID</label>
                                <input type="text" class="form-input" id="editDiscordUserId" disabled>
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="editRobloxUsername">Roblox Username</label>
                                <input type="text" class="form-input" id="editRobloxUsername" placeholder="Auto-filled from Roblox ID on save">
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="editRobloxUserId">Roblox User ID</label>
                                <input type="text" class="form-input" id="editRobloxUserId" placeholder="Leave empty to unlink" inputmode="numeric">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Verification Status</label>
                                <div class="status-toggle" id="editStatus" role="radiogroup" aria-label="Verification Status">
                                    <button type="button" class="status-toggle-btn" data-value="verified" role="radio" aria-checked="false">Verified</button>
                                    <button type="button" class="status-toggle-btn" data-value="unverified" role="radio" aria-checked="false">Unverified</button>
                                </div>
                            </div>
                            <div class="form-error" id="editError"></div>
                            <div class="form-actions">
                                <button type="button" class="btn btn-outline btn-sm" id="editCancelBtn">Cancel</button>
                                <button type="submit" class="btn btn-primary btn-sm" id="editSaveBtn">Save Changes</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <footer class="footer">
        <div class="container">
            <p>&copy; 2026 Aeternorithm Project. All rights reserved.</p>
        </div>
    </footer>

    <script>
    (function() {
        var currentPlayers = [];
        var currentPage = 1;
        var totalPages = 1;
        var searchQuery = '';
        var searchTimer = null;
        var currentPlayerId = null;

        async function loadPlayers() {
            var btn = document.getElementById('refreshBtn');
            var dot = document.getElementById('refreshStatus');
            btn.disabled = true;
            btn.textContent = 'Loading...';
            dot.className = 'status-dot loading';

            try {
                var params = '?page=' + currentPage + '&limit=50';
                if (searchQuery) params += '&search=' + encodeURIComponent(searchQuery);
                var res = await fetch('/api/game/players' + params);
                var data = await res.json();
                if (data.success) {
                    currentPlayers = data.players;
                    totalPages = data.pagination.pages || 1;
                    renderStats(data.stats);
                    renderTable(currentPlayers);
                    renderPagination(data.pagination);
                    dot.className = 'status-dot success';
                } else {
                    dot.className = 'status-dot error';
                }
            } catch(e) {
                dot.className = 'status-dot error';
            }
            btn.disabled = false;
            btn.textContent = 'Refresh';
        }

        function renderStats(stats) {
            document.getElementById('totalMembers').textContent = stats.total || 0;
            document.getElementById('robloxVerified').textContent = (stats.roblox_verified || 0) + ' / ' + ((stats.total || 0) - (stats.roblox_verified || 0));
            document.getElementById('webLinked').textContent = (stats.website_linked || 0) + ' / ' + ((stats.total || 0) - (stats.website_linked || 0));
            document.getElementById('totalWarned').textContent = stats.warned || 0;
            document.getElementById('totalBanned').textContent = stats.banned || 0;
        }

        function formatDate(date) {
            if (!date) return '-';
            var d = new Date(date);
            return d.toLocaleDateString('th-TH', { day: '2-digit', month: '2-digit', year: 'numeric' }) + ' ' +
                   d.toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit' });
        }

        function renderTable(players) {
            var tbody = document.getElementById('playersBody');
            if (players.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" class="empty-state">No members found</td></tr>';
                return;
            }
            tbody.innerHTML = players.map(function(p) {
                // Discord column
                var discordHtml = '<div class="member-info">';
                if (p.discord_avatar) discordHtml += '<img class="member-avatar" src="' + esc(p.discord_avatar) + '" alt="">';
                discordHtml += '<span>' + esc(p.discord_display_name || p.discord_username) + '</span></div>';

                // Roblox account column
                var robloxHtml = p.roblox_verified
                    ? '<span class="verify-badge roblox">' + esc(p.roblox_username || String(p.roblox_user_id)) + '</span>'
                    : '<span class="verify-badge none">Not Verified</span>';

                // Roblox verified at
                var robloxDateHtml = p.roblox_verified_at
                    ? '<span class="muted">' + formatDate(p.roblox_verified_at) + '</span>'
                    : '<span class="muted">-</span>';

                // Web linked
                var webDateHtml = p.website_linked
                    ? '<span class="verify-badge full">' + esc(p.website_username) + '</span>'
                    : '<span class="verify-badge none">Not Linked</span>';

                // Moderation status
                var modHtml = '';
                if (p.banned) {
                    modHtml = '<span class="verify-badge banned">Banned</span>';
                } else if (Number(p.warn_level) === 2) {
                    modHtml = '<span class="verify-badge warn2">Warn 2</span>';
                } else if (Number(p.warn_level) === 1) {
                    modHtml = '<span class="verify-badge warn1">Warn 1</span>';
                } else {
                    modHtml = '<span class="verify-badge none">Clean</span>';
                }

                return '<tr class="clickable-row" data-id="' + p._id + '">' +
                    '<td class="discord-cell">' + discordHtml + '</td>' +
                    '<td class="player-cell">' + robloxHtml + '</td>' +
                    '<td class="muted">' + robloxDateHtml + '</td>' +
                    '<td>' + webDateHtml + '</td>' +
                    '<td>' + modHtml + '</td>' +
                '</tr>';
            }).join('');
        }

        function renderPagination(pg) {
            var el = document.getElementById('pagination');
            if (pg.pages <= 1) { el.innerHTML = ''; return; }

            var html = '';
            html += '<button class="pg-btn" ' + (pg.page <= 1 ? 'disabled' : '') + ' data-page="' + (pg.page - 1) + '">&lsaquo;</button>';

            var start = Math.max(1, pg.page - 2);
            var end = Math.min(pg.pages, pg.page + 2);
            if (start > 1) html += '<button class="pg-btn" data-page="1">1</button><span class="pg-dots">...</span>';
            for (var i = start; i <= end; i++) {
                html += '<button class="pg-btn' + (i === pg.page ? ' active' : '') + '" data-page="' + i + '">' + i + '</button>';
            }
            if (end < pg.pages) html += '<span class="pg-dots">...</span><button class="pg-btn" data-page="' + pg.pages + '">' + pg.pages + '</button>';

            html += '<button class="pg-btn" ' + (pg.page >= pg.pages ? 'disabled' : '') + ' data-page="' + (pg.page + 1) + '">&rsaquo;</button>';
            el.innerHTML = html;
        }

        function esc(str) {
            var d = document.createElement('div');
            d.textContent = str;
            return d.innerHTML;
        }

        function showModal(playerId) {
            var p = currentPlayers.find(function(pl) { return pl._id === playerId; });
            if (!p) return;

            currentPlayerId = playerId;
            document.getElementById('modalTitle').textContent =
                p.discord_display_name || p.discord_username || p.roblox_username || 'Unknown';

            var html = '<div class="detail-grid">';

            // Discord Info
            html += '<div class="detail-section"><h4>Discord</h4><div class="detail-list">';
            html += detailRow('Discord ID', p.discord_user_id || '-');
            html += detailRow('Username', p.discord_username || '-');
            html += detailRow('Display Name', p.discord_display_name || '-');
            var dsStatus = p.discord_status === 'online' ? '<span class="status-badge online">Online</span>' :
                           p.discord_status === 'idle' ? '<span class="status-badge idle">Idle</span>' :
                           p.discord_status === 'dnd' ? '<span class="status-badge dnd">DND</span>' :
                           '<span class="status-badge offline">Offline</span>';
            html += detailRow('Status', dsStatus);
            if (p.discord_joined_at) html += detailRow('Joined Server', new Date(p.discord_joined_at).toLocaleString());
            html += '</div></div>';

            // Roblox Verification
            html += '<div class="detail-section"><h4>Roblox Verification</h4><div class="detail-list">';
            var rVerify = p.roblox_verified ? '<span class="verify-badge roblox">Verified</span>' : '<span class="verify-badge none">Not Verified</span>';
            html += detailRow('Status', rVerify);
            html += detailRow('Roblox Account', p.roblox_username || (p.roblox_user_id ? String(p.roblox_user_id) : '-'));
            html += detailRow('Roblox ID', p.roblox_user_id || '-');
            if (p.roblox_verified_at) html += detailRow('Verified At', new Date(p.roblox_verified_at).toLocaleString());
            html += '</div></div>';

            // Website Verification
            html += '<div class="detail-section"><h4>Website Verification</h4><div class="detail-list">';
            var wVerify = p.website_linked ? '<span class="verify-badge full">Linked</span>' : '<span class="verify-badge none">Not Linked</span>';
            html += detailRow('Status', wVerify);
            if (p.website_linked_at) html += detailRow('Linked At', new Date(p.website_linked_at).toLocaleString());
            html += '</div></div>';

            html += '</div>';

            // Moderation section
            var currentStatus;
            if (p.banned) {
                currentStatus = '<span class="verify-badge banned">Banned</span>';
            } else if (Number(p.warn_level) === 2) {
                currentStatus = '<span class="verify-badge warn2">Warn 2</span>';
            } else if (Number(p.warn_level) === 1) {
                currentStatus = '<span class="verify-badge warn1">Warn 1</span>';
            } else {
                currentStatus = '<span class="verify-badge none">Clean</span>';
            }

            var reasonText = p.banned ? (p.ban_reason || '') :
                             (Number(p.warn_level) > 0 ? (p.warn_reason || '') : '');
            var whenText = p.banned ? (p.banned_at ? new Date(p.banned_at).toLocaleString() : '-') :
                           (Number(p.warn_level) > 0 && p.warned_at ? new Date(p.warned_at).toLocaleString() : '-');

            var modHtml = '<div class="mod-section">' +
                '<h4>Moderation</h4>' +
                '<div class="mod-current">' +
                    '<span class="mod-label">Current:</span>' + currentStatus +
                    (reasonText ? ' <span class="mod-label" style="margin-left:10px;">Reason:</span><span>' + esc(reasonText) + '</span>' : '') +
                    (whenText !== '-' ? ' <span class="mod-label" style="margin-left:10px;">Since:</span><span>' + esc(whenText) + '</span>' : '') +
                '</div>' +
                '<div class="mod-reason-wrap">' +
                    '<input type="text" class="mod-reason" id="modReasonInput" placeholder="Reason (optional)" maxlength="500">' +
                '</div>' +
                '<div class="mod-actions" style="margin-top:10px;">' +
                    '<button type="button" class="btn btn-warn btn-sm" data-mod-action="warn" data-mod-level="1">Warn 1</button>' +
                    '<button type="button" class="btn btn-warn-2 btn-sm" data-mod-action="warn" data-mod-level="2">Warn 2</button>' +
                    '<button type="button" class="btn btn-outline btn-sm" data-mod-action="unwarn">Clear Warn</button>' +
                    '<button type="button" class="btn btn-danger btn-sm" data-mod-action="ban">Ban</button>' +
                    '<button type="button" class="btn btn-success btn-sm" data-mod-action="unban">Unban</button>' +
                '</div>' +
                '<div class="mod-error" id="modError"></div>' +
            '</div>';

            document.getElementById('modalBody').innerHTML = html + modHtml;
            document.getElementById('modalOverlay').classList.add('active');
        }

        function detailRow(label, value) {
            return '<div class="detail-row"><span class="detail-label">' + label + '</span><span class="detail-value">' + value + '</span></div>';
        }

        // Events
        document.getElementById('refreshBtn').addEventListener('click', function() {
            loadPlayers();
        });

        document.getElementById('searchInput').addEventListener('input', function() {
            var q = this.value.trim();
            clearTimeout(searchTimer);
            searchTimer = setTimeout(function() {
                searchQuery = q;
                currentPage = 1;
                loadPlayers();
            }, 300);
        });

        document.getElementById('pagination').addEventListener('click', function(e) {
            var btn = e.target.closest('.pg-btn');
            if (btn && !btn.disabled) {
                currentPage = parseInt(btn.dataset.page);
                loadPlayers();
            }
        });

        document.getElementById('playersBody').addEventListener('click', function(e) {
            var row = e.target.closest('.clickable-row');
            if (row) showModal(row.dataset.id);
        });

        // Moderation button delegation
        document.getElementById('modalBody').addEventListener('click', async function(e) {
            var btn = e.target.closest('button[data-mod-action]');
            if (!btn) return;

            var p = currentPlayers.find(function(pl) { return pl._id === currentPlayerId; });
            if (!p || !p.discord_user_id) return;

            var action = btn.getAttribute('data-mod-action');
            var level = btn.getAttribute('data-mod-level');
            var reasonEl = document.getElementById('modReasonInput');
            var errorEl = document.getElementById('modError');
            if (errorEl) errorEl.textContent = '';

            var reason = reasonEl ? reasonEl.value.trim() : '';

            // Confirm destructive actions
            var confirmMsg = null;
            if (action === 'ban') confirmMsg = 'Ban ' + (p.discord_display_name || p.discord_username) + '?';
            else if (action === 'unban') confirmMsg = 'Unban ' + (p.discord_display_name || p.discord_username) + '?';
            if (confirmMsg && !confirm(confirmMsg)) return;

            // Disable all mod buttons during request
            var allBtns = document.querySelectorAll('#modalBody button[data-mod-action]');
            allBtns.forEach(function(b) { b.disabled = true; });
            var original = btn.textContent;
            btn.textContent = 'Working...';

            try {
                var payload = { action: action, reason: reason };
                if (action === 'warn') payload.level = Number(level);

                var res = await fetch('/api/game/players/' + encodeURIComponent(p.discord_user_id) + '/moderation', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                var data = await res.json();
                if (!res.ok || !data.success) throw new Error(data.error || 'Request failed');

                // Refresh data, close modal
                document.getElementById('modalOverlay').classList.remove('active');
                loadPlayers();
            } catch (err) {
                if (errorEl) errorEl.textContent = err.message || 'Failed to apply moderation action.';
            } finally {
                allBtns.forEach(function(b) { b.disabled = false; });
                btn.textContent = original;
            }
        });

        document.getElementById('modalClose').addEventListener('click', function() {
            document.getElementById('modalOverlay').classList.remove('active');
        });
        document.getElementById('modalOverlay').addEventListener('click', function(e) {
            if (e.target === this) this.classList.remove('active');
        });

        // Copy Layout button
        document.getElementById('copyLayoutBtn').addEventListener('click', function() {
            var p = currentPlayers.find(function(pl) { return pl._id === currentPlayerId; });
            if (!p) return;

            var discordName = p.discord_username || p.discord_display_name || 'Unknown';
            var text = discordName + '\n' +
                'Discord UserID : ' + (p.discord_user_id || '-') + '\n' +
                'Roblox Username : ' + (p.roblox_username || '-') + '\n' +
                'Roblox UserID : ' + (p.roblox_user_id || '-');

            var btn = this;
            var original = btn.textContent;
            function done(ok) {
                btn.textContent = ok ? 'Copied!' : 'Copy failed';
                setTimeout(function() { btn.textContent = original; }, 1500);
            }

            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(text).then(function() { done(true); }, function() { done(false); });
            } else {
                // Fallback
                var ta = document.createElement('textarea');
                ta.value = text;
                ta.style.position = 'fixed';
                ta.style.opacity = '0';
                document.body.appendChild(ta);
                ta.select();
                try { document.execCommand('copy'); done(true); } catch(e) { done(false); }
                document.body.removeChild(ta);
            }
        });

        // Verification status toggle helpers
        function setStatusToggle(value) {
            var btns = document.querySelectorAll('#editStatus .status-toggle-btn');
            btns.forEach(function(b) {
                var active = b.getAttribute('data-value') === value;
                b.classList.toggle('active', active);
                b.setAttribute('aria-checked', active ? 'true' : 'false');
            });
        }
        function getStatusToggle() {
            var active = document.querySelector('#editStatus .status-toggle-btn.active');
            return active ? active.getAttribute('data-value') : 'unverified';
        }
        document.querySelectorAll('#editStatus .status-toggle-btn').forEach(function(b) {
            b.addEventListener('click', function() {
                setStatusToggle(b.getAttribute('data-value'));
            });
        });

        // Edit Data button — open edit modal
        document.getElementById('editDataBtn').addEventListener('click', function() {
            var p = currentPlayers.find(function(pl) { return pl._id === currentPlayerId; });
            if (!p) return;

            document.getElementById('editDiscordUsername').value = p.discord_display_name || p.discord_username || '';
            document.getElementById('editDiscordUserId').value = p.discord_user_id || '';
            document.getElementById('editRobloxUsername').value = p.roblox_username || '';
            document.getElementById('editRobloxUserId').value = p.roblox_user_id || '';
            setStatusToggle(p.roblox_verified ? 'verified' : 'unverified');
            document.getElementById('editError').textContent = '';

            document.getElementById('editModalOverlay').classList.add('active');
        });

        // Edit modal close handlers
        document.getElementById('editModalClose').addEventListener('click', function() {
            document.getElementById('editModalOverlay').classList.remove('active');
        });
        document.getElementById('editCancelBtn').addEventListener('click', function() {
            document.getElementById('editModalOverlay').classList.remove('active');
        });
        document.getElementById('editModalOverlay').addEventListener('click', function(e) {
            if (e.target === this) this.classList.remove('active');
        });

        // Submit edit form
        document.getElementById('editForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            var p = currentPlayers.find(function(pl) { return pl._id === currentPlayerId; });
            if (!p || !p.discord_user_id) return;

            var errorEl = document.getElementById('editError');
            var saveBtn = document.getElementById('editSaveBtn');
            errorEl.textContent = '';

            var robloxIdRaw = document.getElementById('editRobloxUserId').value.trim();
            var robloxUsername = document.getElementById('editRobloxUsername').value.trim();
            var status = getStatusToggle();

            var payload;
            if (robloxIdRaw === '') {
                payload = { roblox_user_id: null };
            } else {
                if (!/^\d+$/.test(robloxIdRaw)) {
                    errorEl.textContent = 'Roblox User ID must be a positive number.';
                    return;
                }
                payload = {
                    roblox_user_id: Number(robloxIdRaw),
                    roblox_username: robloxUsername,
                    status: status
                };
            }

            saveBtn.disabled = true;
            saveBtn.textContent = 'Saving...';

            try {
                var res = await fetch('/api/game/players/' + encodeURIComponent(p.discord_user_id), {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                var data = await res.json();
                if (!res.ok || !data.success) {
                    throw new Error(data.error || 'Request failed');
                }
                document.getElementById('editModalOverlay').classList.remove('active');
                document.getElementById('modalOverlay').classList.remove('active');
                loadPlayers();
            } catch (err) {
                errorEl.textContent = err.message || 'Failed to save changes.';
            } finally {
                saveBtn.disabled = false;
                saveBtn.textContent = 'Save Changes';
            }
        });

        // ====================== Creators (Admin) ======================
        var creatorsCache = [];
        var creatorEditingId = null;
        var creatorEditingSubscribers = 0;
        var creatorSearchQuery = '';

        async function loadCreators() {
            var listEl = document.getElementById('creatorAdminList');
            try {
                var res = await fetch('/api/creators');
                var data = await res.json();
                if (!res.ok || !data.success) {
                    listEl.innerHTML = '<p class="empty-state">Failed to load creators.</p>';
                    return;
                }
                creatorsCache = data.creators || [];
                renderCreatorsList();
            } catch (err) {
                listEl.innerHTML = '<p class="empty-state">Failed to load creators.</p>';
            }
        }

        function renderCreatorsList() {
            var listEl = document.getElementById('creatorAdminList');
            var q = creatorSearchQuery;
            var filtered = !q ? creatorsCache : creatorsCache.filter(function(c) {
                return (c.name || '').toLowerCase().indexOf(q) !== -1 ||
                       (c.handle || '').toLowerCase().indexOf(q) !== -1 ||
                       (c.platform || '').toLowerCase().indexOf(q) !== -1;
            });

            if (filtered.length === 0) {
                listEl.innerHTML = '<p class="empty-state">' + (q ? 'No creators match your search.' : 'No creators yet. Click "Add Creator" to create one.') + '</p>';
                return;
            }

            listEl.innerHTML = filtered.map(function(c) {
                var avatarHtml = c.avatar
                    ? '<img class="creator-row-avatar" src="' + esc(c.avatar) + '" alt="">'
                    : '<span class="creator-row-avatar fallback">' + esc((c.name || '?').charAt(0)) + '</span>';
                var platformBadge = '<span class="platform-badge platform-' + esc(c.platform) + '">' + esc(c.platform) + '</span>';
                var followers = c.followers ? '<span class="muted">· ' + esc(c.followers) + ' followers</span>' : '';
                return '<div class="creator-row" data-id="' + esc(c._id) + '">' +
                    '<div class="creator-row-main">' +
                        avatarHtml +
                        '<div class="creator-row-info">' +
                            '<div class="creator-row-name">' + esc(c.name) + ' ' + platformBadge + '</div>' +
                            '<div class="creator-row-meta"><span class="muted">' + esc(c.handle) + '</span> ' + followers + '</div>' +
                        '</div>' +
                    '</div>' +
                    '<div class="creator-row-actions">' +
                        '<a class="btn btn-outline btn-sm" href="' + esc(c.url) + '" target="_blank" rel="noopener noreferrer">Open</a>' +
                        '<button type="button" class="btn btn-outline btn-sm" data-action="edit">Edit</button>' +
                    '</div>' +
                '</div>';
            }).join('');
        }

        function setCreatorPlatform(value) {
            var btns = document.querySelectorAll('#creatorPlatform .status-toggle-btn');
            btns.forEach(function(b) {
                var active = b.getAttribute('data-value') === value;
                b.classList.toggle('active', active);
                b.setAttribute('aria-checked', active ? 'true' : 'false');
            });
        }
        function getCreatorPlatform() {
            var active = document.querySelector('#creatorPlatform .status-toggle-btn.active');
            return active ? active.getAttribute('data-value') : '';
        }
        document.querySelectorAll('#creatorPlatform .status-toggle-btn').forEach(function(b) {
            b.addEventListener('click', function() {
                setCreatorPlatform(b.getAttribute('data-value'));
            });
        });

        function openCreatorModal(creator) {
            creatorEditingId = creator ? creator._id : null;
            creatorEditingSubscribers = creator && Number.isFinite(creator.subscribers) ? creator.subscribers : 0;
            document.getElementById('creatorModalTitle').textContent = creator ? 'Edit Creator' : 'Add Creator';
            document.getElementById('creatorName').value = creator ? (creator.name || '') : '';
            document.getElementById('creatorHandle').value = creator ? (creator.handle || '') : '';
            document.getElementById('creatorUrl').value = creator ? (creator.url || '') : '';
            document.getElementById('creatorAvatar').value = creator ? (creator.avatar || '') : '';
            document.getElementById('creatorBanner').value = creator ? (creator.banner || '') : '';
            document.getElementById('creatorFollowers').value = creator ? (creator.followers || '') : '';
            document.getElementById('creatorOrder').value = creator ? (creator.order != null ? creator.order : 0) : 0;
            setCreatorPlatform(creator ? creator.platform : 'youtube');
            document.getElementById('creatorError').textContent = '';
            document.getElementById('creatorFetchHint').textContent = 'Paste a YouTube channel URL and click Fetch to auto-fill the rest.';
            document.getElementById('creatorDeleteBtn').hidden = !creator;
            document.getElementById('creatorModalOverlay').classList.add('active');
        }

        function closeCreatorModal() {
            document.getElementById('creatorModalOverlay').classList.remove('active');
            creatorEditingId = null;
        }

        document.getElementById('addCreatorBtn').addEventListener('click', function() {
            openCreatorModal(null);
        });

        document.getElementById('creatorAdminList').addEventListener('click', function(e) {
            var btn = e.target.closest('button[data-action="edit"]');
            if (!btn) return;
            var row = btn.closest('.creator-row');
            if (!row) return;
            var id = row.getAttribute('data-id');
            var creator = creatorsCache.find(function(c) { return String(c._id) === String(id); });
            if (creator) openCreatorModal(creator);
        });

        document.getElementById('creatorModalClose').addEventListener('click', closeCreatorModal);
        document.getElementById('creatorCancelBtn').addEventListener('click', closeCreatorModal);
        document.getElementById('creatorModalOverlay').addEventListener('click', function(e) {
            if (e.target === this) closeCreatorModal();
        });

        document.getElementById('creatorSearchInput').addEventListener('input', function() {
            creatorSearchQuery = this.value.trim().toLowerCase();
            renderCreatorsList();
        });

        document.getElementById('creatorFetchBtn').addEventListener('click', async function() {
            var btn = this;
            var url = document.getElementById('creatorUrl').value.trim();
            var hint = document.getElementById('creatorFetchHint');
            var errorEl = document.getElementById('creatorError');
            errorEl.textContent = '';
            if (!url) { errorEl.textContent = 'Enter a URL first.'; return; }
            btn.disabled = true;
            var prev = btn.textContent;
            btn.textContent = 'Fetching...';
            hint.textContent = 'Fetching channel details...';
            try {
                var res = await fetch('/api/creators/fetch?url=' + encodeURIComponent(url));
                var data = await res.json();
                if (!res.ok || !data.success) throw new Error(data.error || 'Fetch failed');
                var d = data.data || {};
                document.getElementById('creatorName').value = d.name || '';
                document.getElementById('creatorHandle').value = d.handle || '';
                document.getElementById('creatorUrl').value = d.url || url;
                document.getElementById('creatorAvatar').value = d.avatar || '';
                document.getElementById('creatorBanner').value = d.banner || '';
                document.getElementById('creatorFollowers').value = d.followers || '';
                creatorEditingSubscribers = Number(d.subscribers) || 0;
                if (d.platform) setCreatorPlatform(d.platform);
                hint.textContent = 'Loaded ' + (d.name || 'channel') + ' (' + (creatorEditingSubscribers.toLocaleString()) + ' subscribers).';
            } catch (err) {
                hint.textContent = 'Paste a YouTube channel URL and click Fetch to auto-fill the rest.';
                errorEl.textContent = err.message || 'Failed to fetch channel.';
            } finally {
                btn.disabled = false;
                btn.textContent = prev;
            }
        });

        document.getElementById('creatorForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            var errorEl = document.getElementById('creatorError');
            var saveBtn = document.getElementById('creatorSaveBtn');
            errorEl.textContent = '';

            var platform = getCreatorPlatform();
            if (!platform) {
                errorEl.textContent = 'Select a platform.';
                return;
            }

            var payload = {
                name: document.getElementById('creatorName').value.trim(),
                handle: document.getElementById('creatorHandle').value.trim(),
                platform: platform,
                url: document.getElementById('creatorUrl').value.trim(),
                avatar: document.getElementById('creatorAvatar').value.trim(),
                banner: document.getElementById('creatorBanner').value.trim(),
                followers: document.getElementById('creatorFollowers').value.trim(),
                subscribers: Number(creatorEditingSubscribers) || 0,
                order: Number(document.getElementById('creatorOrder').value) || 0
            };

            saveBtn.disabled = true;
            saveBtn.textContent = 'Saving...';
            try {
                var url = '/api/creators' + (creatorEditingId ? '/' + encodeURIComponent(creatorEditingId) : '');
                var method = creatorEditingId ? 'PUT' : 'POST';
                var res = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                var data = await res.json();
                if (!res.ok || !data.success) throw new Error(data.error || 'Request failed');
                closeCreatorModal();
                loadCreators();
            } catch (err) {
                errorEl.textContent = err.message || 'Failed to save creator.';
            } finally {
                saveBtn.disabled = false;
                saveBtn.textContent = 'Save';
            }
        });

        document.getElementById('creatorDeleteBtn').addEventListener('click', async function() {
            if (!creatorEditingId) return;
            if (!confirm('Delete this creator? This cannot be undone.')) return;

            var errorEl = document.getElementById('creatorError');
            var btn = this;
            errorEl.textContent = '';
            btn.disabled = true;
            btn.textContent = 'Deleting...';
            try {
                var res = await fetch('/api/creators/' + encodeURIComponent(creatorEditingId), { method: 'DELETE' });
                var data = await res.json();
                if (!res.ok || !data.success) throw new Error(data.error || 'Request failed');
                closeCreatorModal();
                loadCreators();
            } catch (err) {
                errorEl.textContent = err.message || 'Failed to delete creator.';
            } finally {
                btn.disabled = false;
                btn.textContent = 'Delete';
            }
        });

        loadCreators();

        // Auto refresh every 30s
        loadPlayers();
        setInterval(loadPlayers, 30000);
    })();
    </script>
    <script src="/js/navbar.js"></script>
    <script src="/js/security.js"></script>
</body>
</html>
