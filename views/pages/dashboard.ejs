<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aeternorithm Project</title>
    <link rel="stylesheet" href="/css/pages/dashboard.css">
    <link rel="stylesheet" href="/css/components/scrollbar.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <nav class="navbar">
        <div class="container nav-content">
            <a href="/" class="nav-logo">Aeternorithm</a>
            <div class="nav-menu">
                <ul class="nav-links">
                    <li><a href="/">Home</a></li>
                    <li><a href="/account"><%= user.username %></a></li>
                    <li><a href="/dashboard" class="active">Dashboard</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="page">
        <div class="container">
            <div class="page-header">
                <div>
                    <h1 class="page-title">Dashboard</h1>
                    <p class="page-subtitle">Player data overview</p>
                </div>
                <div class="header-actions">
                    <span class="status-dot" id="refreshStatus"></span>
                    <button class="btn btn-outline btn-sm" id="refreshBtn">Refresh</button>
                </div>
            </div>

            <!-- Stats Summary -->
            <div class="stats-row" id="statsRow">
                <div class="stat-card">
                    <span class="stat-value" id="totalPlayers">-</span>
                    <span class="stat-label">Total Players</span>
                </div>
                <div class="stat-card">
                    <span class="stat-value online" id="onlinePlayers">-</span>
                    <span class="stat-label">Online</span>
                </div>
            </div>

            <!-- Players Table -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">Players</h2>
                    <input type="text" class="search-input" id="searchInput" placeholder="Search by username...">
                </div>
                <div class="table-wrap">
                    <table class="data-table" id="playersTable">
                        <thead>
                            <tr>
                                <th>Status</th>
                                <th>Player</th>
                                <th>Roblox ID</th>
                                <th>Selected Slot</th>
                                <th>Slots</th>
                                <th>Last Seen</th>
                            </tr>
                        </thead>
                        <tbody id="playersBody">
                            <tr><td colspan="6" class="empty-state">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Player Detail Modal -->
            <div class="modal-overlay" id="modalOverlay">
                <div class="modal">
                    <div class="modal-header">
                        <h3 class="modal-title" id="modalTitle">Player Details</h3>
                        <button class="modal-close" id="modalClose">&times;</button>
                    </div>
                    <div class="modal-body" id="modalBody"></div>
                </div>
            </div>
        </div>
    </main>

    <footer class="footer">
        <div class="container">
            <p>&copy; 2026 Aeternorithm Project. All rights reserved.</p>
        </div>
    </footer>

    <script>
    (function() {
        var allPlayers = [];

        function timeAgo(date) {
            var now = Date.now();
            var diff = now - new Date(date).getTime();
            var mins = Math.floor(diff / 60000);
            if (mins < 1) return 'Just now';
            if (mins < 60) return mins + 'm ago';
            var hours = Math.floor(mins / 60);
            if (hours < 24) return hours + 'h ago';
            var days = Math.floor(hours / 24);
            return days + 'd ago';
        }

        async function loadPlayers() {
            var btn = document.getElementById('refreshBtn');
            var dot = document.getElementById('refreshStatus');
            btn.disabled = true;
            btn.textContent = 'Loading...';
            dot.className = 'status-dot loading';

            try {
                var res = await fetch('/api/game/players');
                var data = await res.json();
                if (data.success) {
                    allPlayers = data.players;
                    renderStats();
                    renderTable(allPlayers);
                    dot.className = 'status-dot success';
                } else {
                    dot.className = 'status-dot error';
                }
            } catch(e) {
                dot.className = 'status-dot error';
            }
            btn.disabled = false;
            btn.textContent = 'Refresh';
        }

        function renderStats() {
            document.getElementById('totalPlayers').textContent = allPlayers.length;
            var online = allPlayers.filter(function(p) { return p.is_online; }).length;
            document.getElementById('onlinePlayers').textContent = online;
        }

        function renderTable(players) {
            var tbody = document.getElementById('playersBody');
            if (players.length === 0) {
                tbody.innerHTML = '<tr><td colspan="6" class="empty-state">No players found</td></tr>';
                return;
            }
            tbody.innerHTML = players.map(function(p) {
                var slotCount = (p.created_slots || []).length;

                return '<tr class="clickable-row" data-id="' + p._id + '">' +
                    '<td><span class="status-badge ' + (p.is_online ? 'online' : 'offline') + '">' + (p.is_online ? 'Online' : 'Offline') + '</span></td>' +
                    '<td class="player-cell">' + esc(p.roblox_username || 'Unknown') + '</td>' +
                    '<td>' + p.roblox_user_id + '</td>' +
                    '<td>' + (p.selected_slot || 1) + '</td>' +
                    '<td>' + slotCount + '</td>' +
                    '<td class="muted">' + timeAgo(p.last_seen || p.updated_at) + '</td>' +
                '</tr>';
            }).join('');
        }

        function esc(str) {
            var d = document.createElement('div');
            d.textContent = str;
            return d.innerHTML;
        }

        function showModal(playerId) {
            var p = allPlayers.find(function(pl) { return pl._id === playerId; });
            if (!p) return;

            document.getElementById('modalTitle').textContent =
                (p.roblox_username || 'ID: ' + p.roblox_user_id) + ' - Player Details';

            var html = '<div class="detail-grid">';

            html += '<div class="detail-section"><h4>Player Info</h4><div class="detail-list">';
            html += detailRow('Roblox ID', p.roblox_user_id);
            html += detailRow('Username', p.roblox_username || '-');
            html += detailRow('Status', p.is_online ? '<span class="status-badge online">Online</span>' : '<span class="status-badge offline">Offline</span>');
            html += detailRow('Selected Slot', p.selected_slot || 1);
            html += detailRow('Created Slots', (p.created_slots || []).join(', '));
            html += detailRow('Last Seen', new Date(p.last_seen || p.updated_at).toLocaleString());
            html += '</div></div>';

            // Settings
            var settings = p.settings || {};
            var settingKeys = Object.keys(settings);
            if (settingKeys.length > 0) {
                for (var i = 0; i < settingKeys.length; i++) {
                    var cat = settingKeys[i];
                    var catData = settings[cat];
                    if (typeof catData === 'object' && catData !== null) {
                        html += '<div class="detail-section"><h4>' + esc(cat) + '</h4><div class="detail-list">';
                        for (var key in catData) {
                            html += detailRow(key, catData[key]);
                        }
                        html += '</div></div>';
                    }
                }
            }

            html += '</div>';

            document.getElementById('modalBody').innerHTML = html;
            document.getElementById('modalOverlay').classList.add('active');
        }

        function detailRow(label, value) {
            return '<div class="detail-row"><span class="detail-label">' + label + '</span><span class="detail-value">' + value + '</span></div>';
        }

        // Events
        document.getElementById('refreshBtn').addEventListener('click', loadPlayers);

        document.getElementById('searchInput').addEventListener('input', function() {
            var q = this.value.toLowerCase();
            var filtered = allPlayers.filter(function(p) {
                return (p.roblox_username || '').toLowerCase().includes(q) ||
                       String(p.roblox_user_id).includes(q);
            });
            renderTable(filtered);
        });

        document.getElementById('playersBody').addEventListener('click', function(e) {
            var row = e.target.closest('.clickable-row');
            if (row) showModal(row.dataset.id);
        });

        document.getElementById('modalClose').addEventListener('click', function() {
            document.getElementById('modalOverlay').classList.remove('active');
        });
        document.getElementById('modalOverlay').addEventListener('click', function(e) {
            if (e.target === this) this.classList.remove('active');
        });

        // Auto refresh every 30s
        loadPlayers();
        setInterval(loadPlayers, 30000);
    })();
    </script>
    <script src="/js/security.js"></script>
</body>
</html>
