<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aeternorithm Project</title>
    <link rel="stylesheet" href="/css/pages/dashboard.css">
    <link rel="stylesheet" href="/css/components/scrollbar.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <nav class="navbar">
        <div class="container nav-content">
            <a href="/" class="nav-logo">Aeternorithm</a>
            <div class="nav-menu">
                <ul class="nav-links">
                    <li><a href="/">Home</a></li>
                    <li><a href="/account"><%= user.username %></a></li>
                    <li><a href="/dashboard" class="active">Dashboard</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="page">
        <div class="container">
            <div class="page-header">
                <div>
                    <h1 class="page-title">Dashboard</h1>
                    <p class="page-subtitle">Player data overview</p>
                </div>
                <div class="header-actions">
                    <span class="status-dot" id="refreshStatus"></span>
                    <button class="btn btn-outline btn-sm" id="refreshBtn">Refresh</button>
                </div>
            </div>

            <!-- Stats Summary -->
            <div class="stats-row" id="statsRow">
                <div class="stat-card">
                    <span class="stat-value" id="totalPlayers">-</span>
                    <span class="stat-label">Total Players</span>
                </div>
                <div class="stat-card">
                    <span class="stat-value online" id="onlinePlayers">-</span>
                    <span class="stat-label">Online</span>
                </div>
                <div class="stat-card">
                    <span class="stat-value" id="totalCharacters">-</span>
                    <span class="stat-label">Total Characters</span>
                </div>
            </div>

            <!-- Players Table -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">Players</h2>
                    <input type="text" class="search-input" id="searchInput" placeholder="Search by username...">
                </div>
                <div class="table-wrap">
                    <table class="data-table" id="playersTable">
                        <thead>
                            <tr>
                                <th>Status</th>
                                <th>Player</th>
                                <th>Active Slot</th>
                                <th>Slots</th>
                                <th>Active Character</th>
                                <th>Level</th>
                                <th>Last Seen</th>
                            </tr>
                        </thead>
                        <tbody id="playersBody">
                            <tr><td colspan="7" class="empty-state">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Player Detail Modal -->
            <div class="modal-overlay" id="modalOverlay">
                <div class="modal">
                    <div class="modal-header">
                        <h3 class="modal-title" id="modalTitle">Player Details</h3>
                        <button class="modal-close" id="modalClose">&times;</button>
                    </div>
                    <div class="modal-body" id="modalBody"></div>
                </div>
            </div>
        </div>
    </main>

    <footer class="footer">
        <div class="container">
            <p>&copy; 2026 Aeternorithm Project. All rights reserved.</p>
        </div>
    </footer>

    <script>
    (function() {
        var allPlayers = [];

        function timeAgo(date) {
            var now = Date.now();
            var diff = now - new Date(date).getTime();
            var mins = Math.floor(diff / 60000);
            if (mins < 1) return 'Just now';
            if (mins < 60) return mins + 'm ago';
            var hours = Math.floor(mins / 60);
            if (hours < 24) return hours + 'h ago';
            var days = Math.floor(hours / 24);
            return days + 'd ago';
        }

        function getActiveChar(p) {
            var slot = String(p.selected_slot || 1);
            var chars = p.characters || {};
            return chars[slot] || null;
        }

        function countChars(p) {
            var chars = p.characters || {};
            return Object.keys(chars).length;
        }

        async function loadPlayers() {
            var btn = document.getElementById('refreshBtn');
            var dot = document.getElementById('refreshStatus');
            btn.disabled = true;
            btn.textContent = 'Loading...';
            dot.className = 'status-dot loading';

            try {
                var res = await fetch('/api/game/players');
                var data = await res.json();
                if (data.success) {
                    allPlayers = data.players;
                    renderStats();
                    renderTable(allPlayers);
                    dot.className = 'status-dot success';
                } else {
                    dot.className = 'status-dot error';
                }
            } catch(e) {
                dot.className = 'status-dot error';
            }
            btn.disabled = false;
            btn.textContent = 'Refresh';
        }

        function renderStats() {
            document.getElementById('totalPlayers').textContent = allPlayers.length;
            var online = allPlayers.filter(function(p) { return p.is_online; }).length;
            document.getElementById('onlinePlayers').textContent = online;
            var totalChars = allPlayers.reduce(function(s, p) { return s + countChars(p); }, 0);
            document.getElementById('totalCharacters').textContent = totalChars;
        }

        function renderTable(players) {
            var tbody = document.getElementById('playersBody');
            if (players.length === 0) {
                tbody.innerHTML = '<tr><td colspan="7" class="empty-state">No players found</td></tr>';
                return;
            }
            tbody.innerHTML = players.map(function(p) {
                var activeChar = getActiveChar(p);
                var charName = activeChar ? (activeChar.character_name || '-') : '-';
                var level = activeChar ? (activeChar.level || 1) : '-';
                var slotCount = (p.created_slots || []).length;

                return '<tr class="clickable-row" data-id="' + p._id + '">' +
                    '<td><span class="status-badge ' + (p.is_online ? 'online' : 'offline') + '">' + (p.is_online ? 'Online' : 'Offline') + '</span></td>' +
                    '<td class="player-cell">' + esc(p.roblox_username || 'ID: ' + p.roblox_user_id) + '</td>' +
                    '<td>' + (p.selected_slot || 1) + '</td>' +
                    '<td>' + slotCount + '</td>' +
                    '<td>' + esc(charName) + '</td>' +
                    '<td>' + level + '</td>' +
                    '<td class="muted">' + timeAgo(p.last_seen || p.updated_at) + '</td>' +
                '</tr>';
            }).join('');
        }

        function esc(str) {
            var d = document.createElement('div');
            d.textContent = str;
            return d.innerHTML;
        }

        function showModal(playerId) {
            var p = allPlayers.find(function(pl) { return pl._id === playerId; });
            if (!p) return;

            document.getElementById('modalTitle').textContent =
                (p.roblox_username || 'ID: ' + p.roblox_user_id) + ' - Player Details';

            var html = '<div class="detail-grid">';

            // Player Info
            html += '<div class="detail-section"><h4>Player Info</h4><div class="detail-list">';
            html += detailRow('Roblox ID', p.roblox_user_id);
            html += detailRow('Username', p.roblox_username || '-');
            html += detailRow('Status', p.is_online ? '<span class="status-badge online">Online</span>' : '<span class="status-badge offline">Offline</span>');
            html += detailRow('Selected Slot', p.selected_slot || 1);
            html += detailRow('Created Slots', (p.created_slots || []).join(', '));
            html += detailRow('Last Seen', new Date(p.last_seen || p.updated_at).toLocaleString());
            html += '</div></div>';

            // Character Slots
            var chars = p.characters || {};
            var slots = Object.keys(chars).sort();

            for (var i = 0; i < slots.length; i++) {
                var slotNum = slots[i];
                var c = chars[slotNum];
                var isActive = String(p.selected_slot) === slotNum;
                var slotLabel = 'Slot ' + slotNum + (isActive ? ' (Active)' : '');

                html += '<div class="detail-section"><h4>' + esc(slotLabel) + ' - ' + esc(c.character_name || 'Unnamed') + '</h4><div class="detail-list">';

                // General
                html += detailRow('Name', c.character_name || '-');
                html += detailRow('Gender', c.gender || '-');
                html += detailRow('Age', c.age || 18);

                // Progression
                html += detailRow('Level', c.level || 1);
                html += detailRow('Experience', c.experience || 0);
                html += detailRow('Nex', c.nex || 0);
                html += detailRow('Bounty', c.bounty || 0);
                html += detailRow('Attribute Pts', c.attribute_points || 0);
                html += detailRow('Investment Pts', c.investment_points || 0);

                // Equipment
                html += detailRow('Weapon', c.current_weapon || '-');
                html += detailRow('Arcis', c.current_arcis || '-');

                // Survival (from journal)
                var journal = c.journal || {};
                html += barRow('Hunger', journal.Hunger);
                html += barRow('Water', journal.Water);
                html += barRow('Senses', journal.Senses);
                html += barRow('Armor', journal.Armor);
                html += barRow('Essence', journal.Essence);
                html += barRow('Posture', journal.Posture);

                // Body Stats
                var body = journal.Body || {};
                for (var k in body) {
                    var v = body[k];
                    html += detailRow(k, typeof v === 'object' ? 'Stat: ' + (v.Stats || 0) + ' / Exp: ' + (v.Exp || 0) : v);
                }

                // Weapons
                var weapons = journal.Weapons || {};
                for (var w in weapons) {
                    var wv = weapons[w];
                    html += detailRow(w + ' Weapon', typeof wv === 'object' ? 'Stat: ' + (wv.Stats || 0) + ' / Exp: ' + (wv.Exp || 0) : wv);
                }

                // Arcis
                var arcis = journal.Arcis || {};
                for (var a in arcis) {
                    var av = arcis[a];
                    html += detailRow(a, typeof av === 'object' ? 'Stat: ' + (av.Stats || 0) + ' / Exp: ' + (av.Exp || 0) : av);
                }

                // Resistances
                var resistances = journal.Resistances || {};
                for (var r in resistances) {
                    html += detailRow(r + ' Resist', resistances[r] || 0);
                }

                // Talents
                var talents = c.talents || {};
                var talentKeys = Object.keys(talents);
                if (talentKeys.length > 0) {
                    talentKeys.forEach(function(t) { html += detailRow(t, talents[t] ? 'Active' : 'Inactive'); });
                }

                html += '</div></div>';
            }

            if (slots.length === 0) {
                html += '<div class="detail-section"><h4>Characters</h4><div class="detail-list">';
                html += '<div class="detail-row"><span class="muted">No character data</span></div>';
                html += '</div></div>';
            }

            html += '</div>';

            document.getElementById('modalBody').innerHTML = html;
            document.getElementById('modalOverlay').classList.add('active');
        }

        function detailRow(label, value) {
            return '<div class="detail-row"><span class="detail-label">' + label + '</span><span class="detail-value">' + value + '</span></div>';
        }

        function barRow(label, obj) {
            if (!obj) return detailRow(label, '-');
            var now = obj.now !== undefined ? obj.now : (obj.Now !== undefined ? obj.Now : 0);
            var max = obj.max !== undefined ? obj.max : (obj.Max !== undefined ? obj.Max : 100);
            var pct = max > 0 ? Math.round((now / max) * 100) : 0;
            var color = pct > 60 ? '#22c55e' : pct > 30 ? '#eab308' : '#ef4444';
            return '<div class="detail-row"><span class="detail-label">' + label + '</span>' +
                '<span class="detail-value bar-value"><div class="bar"><div class="bar-fill" style="width:' + pct + '%;background:' + color + '"></div></div>' +
                '<span class="bar-text">' + Math.round(now) + '/' + max + '</span></span></div>';
        }

        // Events
        document.getElementById('refreshBtn').addEventListener('click', loadPlayers);

        document.getElementById('searchInput').addEventListener('input', function() {
            var q = this.value.toLowerCase();
            var filtered = allPlayers.filter(function(p) {
                return (p.roblox_username || '').toLowerCase().includes(q) ||
                       String(p.roblox_user_id).includes(q);
            });
            renderTable(filtered);
        });

        document.getElementById('playersBody').addEventListener('click', function(e) {
            var row = e.target.closest('.clickable-row');
            if (row) showModal(row.dataset.id);
        });

        document.getElementById('modalClose').addEventListener('click', function() {
            document.getElementById('modalOverlay').classList.remove('active');
        });
        document.getElementById('modalOverlay').addEventListener('click', function(e) {
            if (e.target === this) this.classList.remove('active');
        });

        // Auto refresh every 30s
        loadPlayers();
        setInterval(loadPlayers, 30000);
    })();
    </script>
    <script src="/js/security.js"></script>
</body>
</html>
